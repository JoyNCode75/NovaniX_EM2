<UserControl x:Class="NovaniX_EM2.Views.BioControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helpers="clr-namespace:NovaniX_EM2.Helpers" 
             xmlns:viewmodels="clr-namespace:NovaniX_EM2.ViewModels" 
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
             Background="Transparent">
    <UserControl.Resources>
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
    </UserControl.Resources>
    
    <Grid Margin="5,15,15,15">
        <TabControl Background="White" BorderBrush="#DDDDDD" BorderThickness="1">
            <TabItem Header="Particle Counter" FontSize="14" FontWeight="Bold">
                <Grid Margin="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="통신 설정 (Modbus TCP)" FontWeight="Bold" FontSize="16" Foreground="#333" VerticalAlignment="Center"/>
                            <Button Content="파라메터 저장" Command="{Binding SavePmsParametersCommand}" Background="#FF9800" Foreground="White" FontWeight="Bold" Width="100" Height="26" Margin="15,0,0,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="3"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="IP Address :" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                            <TextBox Text="{Binding ParticleIpAddress}" Width="130" Height="26" VerticalContentAlignment="Center" Margin="0,0,20,0"/>

                            <Button Content="Connect" Command="{Binding ConnectParticleCommand}" Background="#2196F3" Foreground="White" Width="90" Height="30" FontWeight="Bold"/>
                            <Button Content="Disconnect" Command="{Binding DisconnectParticleCommand}" Background="#757575" Foreground="White" Width="90" Height="30" Margin="10,0,0,0" FontWeight="Bold"/>
                            
                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                                <Ellipse Width="14" Height="14" Margin="0,0,6,0" Stroke="#9E9E9E" StrokeThickness="1">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#F44336"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsParticleConnected}" Value="True">
                                                    <Setter Property="Fill" Value="#4CAF50"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="4" Color="Black" Opacity="0.3" ShadowDepth="1"/>
                                    </Ellipse.Effect>
                                </Ellipse>

                                <TextBlock FontWeight="Bold" VerticalAlignment="Center" FontSize="14">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Disconnected"/>
                                            <Setter Property="Foreground" Value="#F44336"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsParticleConnected}" Value="True">
                                                    <Setter Property="Text" Value="Connected"/>
                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <Separator Margin="0,0,0,20"/>

                        <TextBlock Text="동작 제어" FontWeight="Bold" FontSize="16" Foreground="#333" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="▶ START" Command="{Binding StartParticleCommand}" Width="120" Height="40" Background="#4CAF50" Foreground="White" FontWeight="Bold" Margin="0,0,15,0"/>
                            <Button Content="■ STOP" Command="{Binding StopParticleCommand}" Width="120" Height="40" Background="#F44336" Foreground="White" FontWeight="Bold" Margin="0,0,30,0"/>

                            <TextBlock Text="동작 상태 :" VerticalAlignment="Center" FontWeight="Bold" FontSize="15" Margin="0,0,10,0"/>

                            <Ellipse Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0" Stroke="#9E9E9E" StrokeThickness="1">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#F44336"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ParticleStatusCode}" Value="0">
                                                <Setter Property="Fill" Value="#9E9E9E"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ParticleStatusCode}" Value="1">
                                                <Setter Property="Fill" Value="#4CAF50"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ParticleStatusCode}" Value="257">
                                                <Setter Property="Fill" Value="#2196F3"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="8" Color="Black" Opacity="0.3" ShadowDepth="1"/>
                                </Ellipse.Effect>
                            </Ellipse>

                            <TextBlock FontWeight="Bold" FontSize="15" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Particle Measuring Alarm"/>
                                        <Setter Property="Foreground" Value="#F44336"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ParticleStatusCode}" Value="0">
                                                <Setter Property="Text" Value="유휴 상태 (Idle)"/>
                                                <Setter Property="Foreground" Value="#9E9E9E"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ParticleStatusCode}" Value="1">
                                                <Setter Property="Text" Value="파티클 측정 중 (Measuring)"/>
                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ParticleStatusCode}" Value="257">
                                                <Setter Property="Text" Value="파티클 측정 중 (Hold)"/>
                                                <Setter Property="Foreground" Value="#2196F3"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        
                        <Separator Margin="0,20,0,20"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">

                                <TextBlock Text="기기 정보 (Device Info)" FontWeight="Bold" FontSize="15" Foreground="#333" Margin="0,0,0,10"/>
                                <DataGrid ItemsSource="{Binding DeviceInfoList}" AutoGenerateColumns="False" HeadersVisibility="Column" 
                                          CanUserAddRows="True" Height="140" Margin="0,0,0,20" 
                                          Background="White" BorderBrush="#CCCCCC" BorderThickness="1" GridLinesVisibility="All">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Controller Info" Binding="{Binding ControllerInfo}" Width="*"/>
                                        <DataGridTextColumn Header="Reading Data" Binding="{Binding ReadingData}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Text="파티클 카운터 셋팅" FontWeight="Bold" FontSize="15" Foreground="#333" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="Repeat Count :" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#555"/>
                                    <TextBox Text="{Binding RepeatCount}" Width="60" Height="26" VerticalContentAlignment="Center" Margin="0,0,20,0"/>

                                    <CheckBox IsChecked="{Binding IsFloatMode}" Content="{Binding ModeText}" VerticalAlignment="Center" Foreground="#555"/>
                                </StackPanel>

                                <TextBlock Text="Sampling Value 셋팅" FontWeight="Bold" FontSize="15" Foreground="#333" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Interval(sec) :" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#555"/>
                                    <TextBox Text="{Binding SampleInterval}" Width="60" Height="26" VerticalContentAlignment="Center" Margin="0,0,20,0"/>

                                    <TextBlock Text="Delay Start(sec) :" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#555"/>
                                    <TextBox Text="{Binding DelayStart}" Width="60" Height="26" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="측정 데이터 결과 (Measurement Data Result)" FontWeight="Bold" FontSize="16" Foreground="#333" Margin="0,0,0,15"/>

                                <Grid Margin="10,0,0,20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#555"/>
                                            <Setter Property="FontSize" Value="14"/>
                                        </Style>
                                    </Grid.Resources>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Start Time :" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ParticleStartTime, FallbackValue='--'}" HorizontalAlignment="Right"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="End Time :" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ParticleEndTime, FallbackValue='--'}" HorizontalAlignment="Right"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Elapsed Time :" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ParticleElapsedTime, FallbackValue='00:00:00'}" HorizontalAlignment="Right"/>
                                </Grid>

                                <Border BorderBrush="#BDBDBD" BorderThickness="1" CornerRadius="4" Background="White" Margin="10,0,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Row="0" Grid.Column="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                                            <TextBlock Text="㎛" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#333"/>
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="1" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                            <TextBlock Text="Σ (n)" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#333"/>
                                        </Border>

                                        <Border Grid.Row="1" Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                                            <TextBlock Text="0.5" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#555" FontSize="15"/>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                            <TextBlock Text="{Binding Part05_Sum, FallbackValue='100,000,000,000'}" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" Foreground="#007ACC" FontSize="16"/>
                                        </Border>

                                        <Border Grid.Row="2" Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                                            <TextBlock Text="5.0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#555" FontSize="15"/>
                                        </Border>
                                        <Border Grid.Row="2" Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="0,0,0,0">
                                            <TextBlock Text="{Binding Part50_Sum, FallbackValue='100,000,000,000'}" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" Foreground="#007ACC" FontSize="16"/>
                                        </Border>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Air Sampler" FontSize="14" FontWeight="Bold">
                <Grid Margin="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="통신 설정 (Modbus TCP)" FontWeight="Bold" FontSize="16" Foreground="#333" VerticalAlignment="Center"/>
                            <Button Content="파라메터 저장" Command="{Binding SavePmsParametersCommand}" Background="#FF9800" Foreground="White" FontWeight="Bold" Width="100" Height="26" Margin="15,0,0,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="3"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="IP Address :" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                            <TextBox Text="{Binding AirSamplerIpAddress}" Width="130" Height="26" VerticalContentAlignment="Center" Margin="0,0,20,0"/>

                            <Button Content="Connect" Command="{Binding ConnectAirSamplerCommand}" Background="#2196F3" Foreground="White" Width="90" Height="30" FontWeight="Bold"/>
                            <Button Content="Disconnect" Command="{Binding DisconnectAirSamplerCommand}" Background="#757575" Foreground="White" Width="90" Height="30" Margin="10,0,0,0" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                                <Ellipse Width="14" Height="14" Margin="0,0,6,0" Stroke="#9E9E9E" StrokeThickness="1">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#F44336"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAirSamplerConnected}" Value="True">
                                                    <Setter Property="Fill" Value="#4CAF50"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="4" Color="Black" Opacity="0.3" ShadowDepth="1"/>
                                    </Ellipse.Effect>
                                </Ellipse>

                                <TextBlock FontWeight="Bold" VerticalAlignment="Center" FontSize="14">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Disconnected"/>
                                            <Setter Property="Foreground" Value="#F44336"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAirSamplerConnected}" Value="True">
                                                    <Setter Property="Text" Value="Connected"/>
                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <Separator Margin="0,0,0,20"/>

                        <TextBlock Text="동작 제어" FontWeight="Bold" FontSize="16" Foreground="#333" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="▶ START" Command="{Binding StartAirSamplerCommand}" Width="120" Height="40" Background="#4CAF50" Foreground="White" FontWeight="Bold" Margin="0,0,15,0"/>
                            <Button Content="■ STOP" Command="{Binding StopAirSamplerCommand}" Width="120" Height="40" Background="#F44336" Foreground="White" FontWeight="Bold" Margin="0,0,30,0"/>

                            <TextBlock Text="동작 상태 :" VerticalAlignment="Center" FontWeight="Bold" FontSize="15" Margin="0,0,10,0"/>

                            <Ellipse Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0" Stroke="#9E9E9E" StrokeThickness="1">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#F44336"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AirSamplerStatusCode}" Value="0">
                                                <Setter Property="Fill" Value="#9E9E9E"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AirSamplerStatusCode}" Value="1">
                                                <Setter Property="Fill" Value="#4CAF50"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AirSamplerStatusCode}" Value="257">
                                                <Setter Property="Fill" Value="#2196F3"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AirSamplerStatusCode}" Value="513">
                                                <Setter Property="Fill" Value="#2196F3"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AirSamplerStatusCode}" Value="769">
                                                <Setter Property="Fill" Value="#2196F3"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="8" Color="Black" Opacity="0.3" ShadowDepth="1"/>
                                </Ellipse.Effect>
                            </Ellipse>

                            <TextBlock FontWeight="Bold" FontSize="15" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Flow Alarm"/>
                                        <Setter Property="Foreground" Value="#F44336"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AirSamplerStatusCode}" Value="0">
                                                <Setter Property="Text" Value="유휴 상태 (Idle)"/>
                                                <Setter Property="Foreground" Value="#9E9E9E"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AirSamplerStatusCode}" Value="1">
                                                <Setter Property="Text" Value="Air Sampling 상태"/>
                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AirSamplerStatusCode}" Value="257">
                                                <Setter Property="Text" Value="Air Sampling (홀드/지연)"/>
                                                <Setter Property="Foreground" Value="#2196F3"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AirSamplerStatusCode}" Value="513">
                                                <Setter Property="Text" Value="Air Sampling (Lo Flow)"/>
                                                <Setter Property="Foreground" Value="#2196F3"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AirSamplerStatusCode}" Value="769">
                                                <Setter Property="Text" Value="Air Sampling (Hi Flow)"/>
                                                <Setter Property="Foreground" Value="#2196F3"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <Separator Margin="0,20,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">

                                <TextBlock Text="기기 정보 (Device Info)" FontWeight="Bold" FontSize="15" Foreground="#333" Margin="0,0,0,10"/>
                                <DataGrid ItemsSource="{Binding AirSamplerDeviceInfoList}" AutoGenerateColumns="False" HeadersVisibility="Column" 
                                          CanUserAddRows="True" Height="140" Margin="0,0,0,20" 
                                          Background="White" BorderBrush="#CCCCCC" BorderThickness="1" GridLinesVisibility="All">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Controller Info" Binding="{Binding ControllerInfo}" Width="*"/>
                                        <DataGridTextColumn Header="Reading Data" Binding="{Binding ReadingData}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Text="에어 샘플러 셋팅" FontWeight="Bold" FontSize="15" Foreground="#333" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="Repeat Count :" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#555"/>
                                    <TextBox Text="{Binding AirSamplerRepeatCount}" Width="60" Height="26" VerticalContentAlignment="Center" Margin="0,0,20,0"/>

                                    <CheckBox IsChecked="{Binding AirSamplerIsFloatMode}" Content="{Binding AirSamplerModeText}" VerticalAlignment="Center" Foreground="#555" Margin="0,0,15,0"/>
                                    <CheckBox IsChecked="{Binding AirSamplerIsVolumeMode}" Content="{Binding AirSamplerVolumeModeText}" VerticalAlignment="Center" Foreground="#555"/>
                                </StackPanel>

                                <TextBlock Text="Sampling Value 셋팅" FontWeight="Bold" FontSize="15" Foreground="#333" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding AirSamplerIntervalLabelText}" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#555"/>
                                    <TextBox Text="{Binding AirSamplerInterval}" Width="50" Height="26" VerticalContentAlignment="Center" Margin="0,0,10,0"/>

                                    <TextBlock Text="Hold/Tare :" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#555"/>
                                    <TextBox Text="{Binding AirSamplerHoldTime}" Width="50" Height="26" VerticalContentAlignment="Center" Margin="0,0,10,0"/>

                                    <TextBlock Text="Delay :" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#555"/>
                                    <TextBox Text="{Binding AirSamplerDelayTime}" Width="50" Height="26" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="측정 데이터 결과 (Sampling Data Result)" FontWeight="Bold" FontSize="16" Foreground="#333" Margin="0,0,0,15"/>

                                <Grid Margin="10,0,0,20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#555"/>
                                            <Setter Property="FontSize" Value="14"/>
                                        </Style>
                                    </Grid.Resources>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Start Time :" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AirSamplerStartTime, FallbackValue='02/24/2025 00:00:00'}" HorizontalAlignment="Right"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="End Time :" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AirSamplerEndTime, FallbackValue='02/24/2025 00:00:00'}" HorizontalAlignment="Right"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Elapse Time :" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AirSamplerElapseTime, FallbackValue='00:00:00'}" HorizontalAlignment="Right"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Sampling Volume :" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding AirSamplerMeasureVolume, FallbackValue='0.0 L'}" HorizontalAlignment="Right"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Sampling Flow :" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding AirSamplerMeasureFlow, FallbackValue='0.0 LPM'}" HorizontalAlignment="Right"/>
                                </Grid>

                                <Border BorderBrush="#BDBDBD" BorderThickness="1" CornerRadius="4" Background="White" Margin="10,0,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Row="0" Grid.Column="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                                            <TextBlock Text="Data" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#333"/>
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="1" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                            <TextBlock Text="Result" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#333"/>
                                        </Border>

                                        <Border Grid.Row="1" Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                                            <TextBlock Text="Volume(ℓ)" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#555" FontSize="15"/>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                            <TextBlock Text="{Binding AirSamplerVolumeResult, FallbackValue='0'}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#007ACC" FontSize="16"/>
                                        </Border>

                                        <Border Grid.Row="2" Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                                            <TextBlock Text="Interval Time" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#555" FontSize="15"/>
                                        </Border>
                                        <Border Grid.Row="2" Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="0,0,0,0">
                                            <TextBlock Text="{Binding AirSamplerIntervalTimeResult, FallbackValue='00m : 00s'}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#007ACC" FontSize="16"/>
                                        </Border>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>