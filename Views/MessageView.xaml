<Window x:Class="NovaniX_EM2.Views.MessageView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="메시지" Height="250" Width="450" 
        WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow" Topmost="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="❓" FontSize="60" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10"/>

        <TextBlock x:Name="TxtMessage" Grid.Row="0" Grid.Column="1" Text="메시지 내용"
                   VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="#333" TextWrapping="Wrap" Margin="10,0,0,0"/>

        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="BtnConfirm" Content="확인" Width="100" Height="40" Background="#4CAF50" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,15,0" Click="BtnConfirm_Click" Visibility="Collapsed"/>
            <Button x:Name="BtnWait" Content="대기" Width="100" Height="40" Background="#FF9800" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,15,0" Click="BtnWait_Click" Visibility="Collapsed"/>
            <Button x:Name="BtnCancel" Content="취소" Width="100" Height="40" Background="#F44336" Foreground="White" FontWeight="Bold" FontSize="14" Click="BtnCancel_Click" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>