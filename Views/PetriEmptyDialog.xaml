<Window x:Class="NovaniX_EM2.Views.PetriEmptyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Petri Dish 보충 알림" Height="250" Width="450" 
        WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow" Topmost="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Image Grid.Row="0" Grid.Column="0" Source="/Resources/warning_icon.png" Stretch="Uniform" Margin="10"/>

        <TextBlock Grid.Row="0" Grid.Column="1" Text="로딩할 Petri Dish가 소진되었습니다.&#x0a;새 Petri Dish를 투입한 후 '재실행'을 누르거나,&#x0a;작업을 멈추려면 '동작 정지'를 눌러주세요." 
                   VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="#333" TextWrapping="Wrap" Margin="10,0,0,0"/>

        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="재실행 (카운트 초기화)" Width="160" Height="40" Background="#4CAF50" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,15,0" Click="BtnResume_Click"/>
            <Button Content="동작 정지" Width="120" Height="40" Background="#F44336" Foreground="White" FontWeight="Bold" FontSize="14" Click="BtnStop_Click"/>
        </StackPanel>
    </Grid>
</Window>