<UserControl x:Class="NovaniX_EM2.Views.MainControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NovaniX_EM2.Views"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1280"
             Background="#F0F0F0">

    <UserControl.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ControlButtonStyle" TargetType="ButtonBase">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Height" Value="60"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <GroupBox Header="장비 조작 패널">
                <StackPanel>
                    <Button Content="장비 초기화" Style="{StaticResource ControlButtonStyle}" Background="#2196F3" Foreground="White"
                            Command="{Binding TaskController.InitializeCommand}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ToggleButton Grid.Column="0" Command="{Binding TaskController.ToggleStartStopCommand}" 
                                      IsChecked="{Binding TaskController.StartStopToggleIsChecked, Mode=OneWay}">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton" BasedOn="{StaticResource ControlButtonStyle}">
                                    <Setter Property="Content" Value="장비 동작 시작"/>
                                    <Setter Property="Background" Value="#4CAF50"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TaskController.IsRunning}" Value="True">
                                            <Setter Property="Content" Value="장비 동작 정지"/>
                                            <Setter Property="Background" Value="#F44336"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>

                        <Button Grid.Column="1" Command="{Binding TaskController.PauseResumeCommand}" Foreground="White">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ControlButtonStyle}">
                                    <Setter Property="Content" Value="일시 정지"/>
                                    <Setter Property="Background" Value="#FF9800"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TaskController.CurrentState}" Value="Paused">
                                            <Setter Property="Content" Value="동작 재개"/>
                                            <Setter Property="Background" Value="#FFB300"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TaskController.IsRunning}" Value="False">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Background" Value="#CCCCCC"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="동작 상태 및 진행률">
                <StackPanel>
                    <TextBlock Text="현재 동작 상태" FontSize="15" Foreground="#555" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TaskController.CurrentTaskName}" FontSize="24" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,15"/>

                    <TextBlock Text="{Binding TaskController.ProgressRate, StringFormat='공정 진행률: {0}%'}" FontSize="15" Margin="0,0,0,5"/>
                    <ProgressBar Value="{Binding TaskController.ProgressRate}" Minimum="0" Maximum="100" Height="25" Foreground="#4CAF50" Margin="0,0,0,15"/>

                    <TextBlock Text="최근 알람 메시지" FontSize="15" Foreground="#555" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TaskController.RecentAlarm}" FontSize="16" FontWeight="Bold" Foreground="#F44336" TextWrapping="Wrap"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="Petri Dish 트레이 상태 (Load / Unload)" Margin="10,0,10,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="5">
                        <TextBlock Text="Loading Tray" FontWeight="Bold" FontSize="16" Foreground="#4CAF50" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                            <TextBlock Text="초기 세팅: " VerticalAlignment="Center" FontSize="14"/>
                            <TextBox Text="{Binding TaskController.InitialPetriLoadCount, UpdateSourceTrigger=PropertyChanged}" Width="40" TextAlignment="Center" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="{Binding TaskController.Petri_LoadCount, StringFormat=' / 남음: {0}'}" VerticalAlignment="Center" FontSize="14" Foreground="#555" FontWeight="Bold" Margin="5,0,0,0"/>
                        </StackPanel>

                        <Grid Width="140" Height="240" Margin="0,5,0,0">
                            <Border Width="12" Background="#9E9E9E" HorizontalAlignment="Left" CornerRadius="4,4,0,0"/>
                            <Border Width="12" Background="#9E9E9E" HorizontalAlignment="Right" CornerRadius="4,4,0,0"/>

                            <ItemsControl ItemsSource="{Binding TaskController.LoadPetriVisibilities}" VerticalAlignment="Bottom" Margin="0,0,0,5" HorizontalAlignment="Center">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="100" Height="14" Background="#81C784" CornerRadius="4" Margin="0,1" Visibility="{Binding}">
                                            <Border.Effect>
                                                <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="2" ShadowDepth="1"/>
                                            </Border.Effect>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" Margin="5">
                        <TextBlock Text="Unloading Tray" FontWeight="Bold" FontSize="16" Foreground="#FF9800" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                            <TextBlock Text="적재 수량: " VerticalAlignment="Center" FontSize="14"/>
                            <TextBlock Text="{Binding TaskController.Petri_UnloadCount}" Width="30" TextAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="#FF9800"/>
                            <TextBlock Text="{Binding TaskController.InitialPetriLoadCount, StringFormat=' / {0}'}" VerticalAlignment="Center" FontSize="14" Foreground="#555" FontWeight="Bold"/>
                        </StackPanel>

                        <Grid Width="140" Height="240" Margin="0,5,0,0">
                            <Border Width="12" Background="#9E9E9E" HorizontalAlignment="Left" CornerRadius="4,4,0,0"/>
                            <Border Width="12" Background="#9E9E9E" HorizontalAlignment="Right" CornerRadius="4,4,0,0"/>

                            <ItemsControl ItemsSource="{Binding TaskController.UnloadPetriVisibilities}" VerticalAlignment="Bottom" Margin="0,0,0,5" HorizontalAlignment="Center">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="100" Height="14" Background="#FFB74D" CornerRadius="4" Margin="0,1" Visibility="{Binding}">
                                            <Border.Effect>
                                                <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="2" ShadowDepth="1"/>
                                            </Border.Effect>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </StackPanel>

        <GroupBox Grid.Column="1" Header="검사 및 측정 결과">
            <TabControl Background="White" BorderBrush="#DDDDDD" BorderThickness="1">

                <TabItem Header="Particle Counter" FontSize="14" FontWeight="Bold">
                    <Grid Margin="10">
                        <StackPanel>
                            <TextBlock Text="측정 데이터 결과 (Measurement Data Result)" FontWeight="Bold" FontSize="16" Foreground="#333" Margin="0,0,0,15"/>

                            <Grid Margin="10,0,0,20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#555"/>
                                        <Setter Property="FontSize" Value="14"/>
                                    </Style>
                                </Grid.Resources>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Start Time :" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ParticleStartTime, FallbackValue='--'}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="End Time :" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ParticleEndTime, FallbackValue='--'}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Elapsed Time :" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ParticleElapsedTime, FallbackValue='00:00:00'}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Border BorderBrush="#BDBDBD" BorderThickness="1" CornerRadius="4" Background="White" Margin="10,0,0,15">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="35"/>
                                        <RowDefinition Height="40"/>
                                        <RowDefinition Height="40"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                                        <TextBlock Text="㎛" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#333"/>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="1" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                        <TextBlock Text="Σ (n)" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#333"/>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                                        <TextBlock Text="0.5" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#555" FontSize="15"/>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                        <TextBlock Text="{Binding Part05_Sum, FallbackValue='0'}" Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" Foreground="#007ACC" FontSize="16"/>
                                    </Border>

                                    <Border Grid.Row="2" Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                                        <TextBlock Text="5.0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#555" FontSize="15"/>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="0,0,0,0">
                                        <TextBlock Text="{Binding Part50_Sum, FallbackValue='0'}" Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" Foreground="#007ACC" FontSize="16"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <DataGrid ItemsSource="{Binding ParticleCounterDataList}" AutoGenerateColumns="True" IsReadOnly="True" MinHeight="200"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
                <TabItem Header="Air Sampler" FontSize="14" FontWeight="Bold">
                    <Grid Margin="10">
                        <StackPanel>
                            <TextBlock Text="측정 데이터 결과 (Sampling Data Result)" FontWeight="Bold" FontSize="16" Foreground="#333" Margin="0,0,0,15"/>

                            <Grid Margin="10,0,0,20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#555"/>
                                        <Setter Property="FontSize" Value="14"/>
                                    </Style>
                                </Grid.Resources>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Start Time :" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AirSamplerStartTime, FallbackValue='02/24/2025 00:00:00'}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="End Time :" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AirSamplerEndTime, FallbackValue='02/24/2025 00:00:00'}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Elapse Time :" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AirSamplerElapseTime, FallbackValue='00:00:00'}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Sampling Volume :" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding AirSamplerMeasureVolume, FallbackValue='0.0 L'}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Sampling Flow :" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding AirSamplerMeasureFlow, FallbackValue='0.0 LPM'}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Border BorderBrush="#BDBDBD" BorderThickness="1" CornerRadius="4" Background="White" Margin="10,0,0,15">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="35"/>
                                        <RowDefinition Height="40"/>
                                        <RowDefinition Height="40"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                                        <TextBlock Text="Data" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#333"/>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="1" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                        <TextBlock Text="Result" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#333"/>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                                        <TextBlock Text="Volume(ℓ)" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#555" FontSize="15"/>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                        <TextBlock Text="{Binding AirSamplerVolumeResult, FallbackValue='0'}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#007ACC" FontSize="16"/>
                                    </Border>

                                    <Border Grid.Row="2" Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                                        <TextBlock Text="Interval Time" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#555" FontSize="15"/>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="0,0,0,0">
                                        <TextBlock Text="{Binding AirSamplerIntervalTimeResult, FallbackValue='00m : 00s'}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#007ACC" FontSize="16"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <DataGrid ItemsSource="{Binding AirSamplerDataList}" AutoGenerateColumns="True" IsReadOnly="True" MinHeight="200"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </GroupBox>
    </Grid>
</UserControl>