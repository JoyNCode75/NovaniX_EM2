<UserControl x:Class="NovaniX_EM2.Views.MainControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NovaniX_EM2.Views"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1280"
             Background="#2C3E50">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>

        <Style x:Key="ControlButtonStyle" TargetType="ButtonBase">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="DarkDataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4.5*"/>
            <ColumnDefinition Width="5.5*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <GroupBox Header="동작 상태 및 진행률">
                <StackPanel>
                    <TextBlock Text="현재 동작 상태" FontSize="15" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TaskController.CurrentTaskName}" FontSize="24" FontWeight="Bold" Foreground="#4FC3F7" Margin="0,0,0,15"/>

                    <TextBlock Text="{Binding TaskController.ProgressRate, StringFormat='공정 진행률: {0}%'}" FontSize="15" Margin="0,0,0,5"/>
                    <ProgressBar Value="{Binding TaskController.ProgressRate}" Minimum="0" Maximum="100" Height="25" Foreground="#66BB6A" Background="#333333" BorderBrush="#555555" Margin="0,0,0,15"/>

                    <TextBlock Text="최근 알람 메시지" FontSize="15" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TaskController.RecentAlarm}" FontSize="16" FontWeight="Bold" Foreground="#E57373" TextWrapping="Wrap"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Petri Dish/Air Sampler Cap 트레이 상태 (Load / Unload)">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="5">
                        <TextBlock Text="Loading Tray" FontWeight="Bold" FontSize="16" Foreground="#81C784" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                            <TextBlock Text="초기 세팅: " VerticalAlignment="Center" FontSize="14"/>
                            <TextBox Text="{Binding TaskController.InitialPetriLoadCount, UpdateSourceTrigger=PropertyChanged}" Width="40" TextAlignment="Center" FontSize="14" FontWeight="Bold" Background="#252526" Foreground="White" BorderBrush="#555555"/>
                            <TextBlock Text="{Binding TaskController.Petri_LoadCount, StringFormat=' / 남음: {0}'}" VerticalAlignment="Center" FontSize="14" Foreground="#AAAAAA" FontWeight="Bold" Margin="5,0,0,0"/>
                        </StackPanel>
                        <Grid Width="140" Height="240" Margin="0,5,0,0">
                            <Border Width="12" Background="#444444" HorizontalAlignment="Left" CornerRadius="4,4,0,0"/>
                            <Border Width="12" Background="#444444" HorizontalAlignment="Right" CornerRadius="4,4,0,0"/>
                            <ItemsControl ItemsSource="{Binding TaskController.LoadPetriVisibilities}" VerticalAlignment="Bottom" Margin="0,0,0,5" HorizontalAlignment="Center">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="100" Height="14" Background="#81C784" CornerRadius="4" Margin="0,1" Visibility="{Binding}">
                                            <Border.Effect>
                                                <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="3" ShadowDepth="1"/>
                                            </Border.Effect>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" Margin="5">
                        <TextBlock Text="Unloading Tray" FontWeight="Bold" FontSize="16" Foreground="#FFB74D" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                            <TextBlock Text="적재 수량: " VerticalAlignment="Center" FontSize="14"/>
                            <TextBlock Text="{Binding TaskController.Petri_UnloadCount}" Width="30" TextAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="#FFB74D"/>
                            <TextBlock Text="{Binding TaskController.InitialPetriLoadCount, StringFormat=' / {0}'}" VerticalAlignment="Center" FontSize="14" Foreground="#AAAAAA" FontWeight="Bold"/>
                        </StackPanel>
                        <Grid Width="140" Height="240" Margin="0,5,0,0">
                            <Border Width="12" Background="#444444" HorizontalAlignment="Left" CornerRadius="4,4,0,0"/>
                            <Border Width="12" Background="#444444" HorizontalAlignment="Right" CornerRadius="4,4,0,0"/>
                            <ItemsControl ItemsSource="{Binding TaskController.UnloadPetriVisibilities}" VerticalAlignment="Bottom" Margin="0,0,0,5" HorizontalAlignment="Center">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="100" Height="14" Background="#FFB74D" CornerRadius="4" Margin="0,1" Visibility="{Binding}">
                                            <Border.Effect>
                                                <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="3" ShadowDepth="1"/>
                                            </Border.Effect>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </StackPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Header="검사 및 측정 결과">
                <TabControl Background="#2C3E50" BorderBrush="#444444" BorderThickness="1" Cursor="">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="TabBorder" Background="#2D2D30" BorderBrush="#444444" BorderThickness="1,1,1,0" Margin="0,0,2,0" Padding="25,10" CornerRadius="4,4,0,0">
                                            <ContentPresenter x:Name="TabContent" ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="TabBorder" Property="Background" Value="#1E1E1E"/>
                                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="1,1,1,0"/>
                                                <Setter Property="Foreground" Value="#4FC3F7"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="False">
                                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                    <Condition Property="IsSelected" Value="False"/>
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="TabBorder" Property="Background" Value="#3E3E42"/>
                                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>
                    <TabItem Header="Particle Counter">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="120"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="측정 데이터 결과 (Measurement Data Result)" FontWeight="Bold" FontSize="16" Foreground="#E0E0E0" Margin="0,0,0,5"/>
                                <Grid Margin="10,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding ParticleStartTime, StringFormat='Start Time : {0}'}" Foreground="#AAAAAA"/>
                                        <TextBlock Text="{Binding ParticleEndTime, StringFormat='End Time : {0}'}" Foreground="#AAAAAA"/>
                                        <TextBlock Text="{Binding ParticleElapsedTime, StringFormat='Elapsed Time : {0}'}" Foreground="#AAAAAA"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Part05_Sum, StringFormat='0.5㎛ 합계 : {0}'}" FontWeight="Bold" Foreground="#4FC3F7" FontSize="15"/>
                                        <TextBlock Text="{Binding Part50_Sum, StringFormat='5.0㎛ 합계 : {0}'}" FontWeight="Bold" Foreground="#E57373" FontSize="15"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <DataGrid Grid.Row="1" ItemsSource="{Binding ParticleCounterDataList}" AutoGenerateColumns="True" IsReadOnly="True" Margin="0,5,0,10"
                                      Background="#1E1E1E" RowBackground="#252526" AlternatingRowBackground="#2D2D30" 
                                      Foreground="#E0E0E0" BorderBrush="#444444" HorizontalGridLinesBrush="#333333" VerticalGridLinesBrush="#333333"
                                      HeadersVisibility="Column" ColumnHeaderStyle="{StaticResource DarkDataGridHeaderStyle}"/>

                            <lvc:CartesianChart Grid.Row="2" Series="{Binding ParticleSeries}" LegendLocation="Top" Margin="0,5,0,0" Foreground="#E0E0E0">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Title="측정 횟수" Labels="{Binding ParticleLabels}" Foreground="#AAAAAA">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Stroke="#333333" />
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title="0.5㎛ Count" MinValue="0" Foreground="#4FC3F7">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Step="100" Stroke="#333333" />
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                    <lvc:Axis Title="5.0㎛ Count" MinValue="100" Position="RightTop" Foreground="#E57373">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Step="1000" Stroke="#333333" />
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Air Sampler">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="120"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="측정 데이터 결과 (Sampling Data Result)" FontWeight="Bold" FontSize="16" Foreground="#E0E0E0" Margin="0,0,0,5"/>
                                <Grid Margin="10,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding AirSamplerStartTime, StringFormat='Start : {0}'}" Foreground="#AAAAAA"/>
                                        <TextBlock Text="{Binding AirSamplerEndTime, StringFormat='End : {0}'}" Foreground="#AAAAAA"/>
                                        <TextBlock Text="{Binding AirSamplerMeasureVolume, StringFormat='Volume : {0}'}" Foreground="#AAAAAA"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding AirSamplerVolumeResult, StringFormat='Volume Result : {0} L'}" FontWeight="Bold" Foreground="#4FC3F7" FontSize="15"/>
                                        <TextBlock Text="{Binding AirSamplerIntervalTimeResult, StringFormat='Interval : {0}'}" FontWeight="Bold" Foreground="#4FC3F7" FontSize="15"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <DataGrid Grid.Row="1" ItemsSource="{Binding AirSamplerDataList}" AutoGenerateColumns="True" IsReadOnly="True" Margin="0,5,0,10"
                                      Background="#1E1E1E" RowBackground="#252526" AlternatingRowBackground="#2D2D30" 
                                      Foreground="#E0E0E0" BorderBrush="#444444" HorizontalGridLinesBrush="#333333" VerticalGridLinesBrush="#333333"
                                      HeadersVisibility="Column" ColumnHeaderStyle="{StaticResource DarkDataGridHeaderStyle}"/>

                            <lvc:CartesianChart Grid.Row="2" Series="{Binding AirSamplerSeries}" LegendLocation="Top" Margin="0,5,0,0" Foreground="#E0E0E0">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Title="측정 횟수" Labels="{Binding AirSamplerLabels}" Foreground="#AAAAAA">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Stroke="#333333" />
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title="Interval Time (Sec)" MinValue="0" Foreground="#4FC3F7">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Step="10" Stroke="#333333" />
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </Grid>
                    </TabItem>
                </TabControl>
            </GroupBox>

            <GroupBox Grid.Row="1" Header="장비 조작 패널">
                <Grid Cursor="">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="장비 초기화" Style="{StaticResource ControlButtonStyle}" Background="#1976D2" Foreground="White"
                            Command="{Binding TaskController.InitializeCommand}"/>

                    <ToggleButton Grid.Column="1" Command="{Binding TaskController.ToggleStartStopCommand}" 
                                  IsChecked="{Binding TaskController.StartStopToggleIsChecked, Mode=OneWay}">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton" BasedOn="{StaticResource ControlButtonStyle}">
                                <Setter Property="Content" Value="동작 시작"/>
                                <Setter Property="Background" Value="#388E3C"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TaskController.IsRunning}" Value="True">
                                        <Setter Property="Content" Value="동작 정지"/>
                                        <Setter Property="Background" Value="#D32F2F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>

                    <Button Grid.Column="2" Command="{Binding TaskController.PauseResumeCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ControlButtonStyle}">
                                <Setter Property="Content" Value="일시 정지"/>
                                <Setter Property="Background" Value="#FFB300"/>
                                <Setter Property="Foreground" Value="#121212"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TaskController.CurrentState}" Value="Paused">
                                        <Setter Property="Content" Value="동작 재개"/>
                                        <Setter Property="Background" Value="#00ACC1"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding TaskController.IsRunning}" Value="False">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Background" Value="#444444"/>
                                        <Setter Property="Foreground" Value="#888888"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>