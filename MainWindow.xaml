<Window x:Class="NovaniX_EM2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:NovaniX_EM2.ViewModels"
        xmlns:views="clr-namespace:NovaniX_EM2.Views"
        Title="NovaniX EM2 - Multi Controller" 
        Height="1024" Width="1280" 
        MinWidth="640" MinHeight="700"
        WindowStyle="None" ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <viewmodels:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="MenuListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="5,15"/>
            <Setter Property="Foreground" Value="#B0BEC5"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="5,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34495E"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1A252F"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#4CAF50"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
            <Grid>
                <Image Source="pack://application:,,,/Images/UnderLogo.png" 
                       Width="150" Height="35" Stretch="Uniform" HorizontalAlignment="Left"
                       VerticalAlignment="Center" Margin="10,0,0,0" 
                       RenderOptions.BitmapScalingMode="HighQuality" 
                       MouseLeftButtonDown="Logo_MouseLeftButtonDown" Cursor="Hand"/>

                <TextBlock Text="EM Second Concept System" 
                           Foreground="White" FontSize="20" FontWeight="Bold" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="{Binding CurrentDateTime}" 
                               Foreground="White" FontSize="16" FontWeight="SemiBold" 
                               Margin="0,0,15,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="65"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="1" Background="#ECF0F1">
                <ContentControl x:Name="MainContent"/>
            </Grid>

            <Border x:Name="MenuBorder" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left" Width="65" Panel.ZIndex="10" Background="#1E2A38">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.4" BlurRadius="8" ShadowDepth="3" Direction="315"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListBox x:Name="MenuListBox" Grid.Row="0" Background="Transparent" BorderThickness="0" Margin="0,15,0,0" SelectionChanged="MenuListBox_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <StaticResource ResourceKey="MenuListItemStyle"/>
                            </ListBox.ItemContainerStyle>

                            <ListBoxItem IsSelected="True" Tag="Main">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏠" FontSize="20" Width="40" TextAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="TxtMenuMain" Text="Main View" VerticalAlignment="Center" Visibility="Collapsed"/>
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem Tag="Bio">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🧪" FontSize="20" Width="40" TextAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="TxtMenuBio" Text="Bio Control" VerticalAlignment="Center" Visibility="Collapsed"/>
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem Tag="Motion">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙️" FontSize="20" Width="40" TextAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="TxtMenuMotion" Text="Motion Control" VerticalAlignment="Center" Visibility="Collapsed"/>
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem Tag="Etc">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🎛️" FontSize="20" Width="40" TextAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="TxtMenuEtc" Text="Etc. I/O" VerticalAlignment="Center" Visibility="Collapsed"/>
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem Tag="System">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🖥️" FontSize="20" Width="40" TextAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="TxtMenuSys" Text="System Setup" VerticalAlignment="Center" Visibility="Collapsed"/>
                                </StackPanel>
                            </ListBoxItem>
                        </ListBox>

                        <Button x:Name="BtnExit" Grid.Row="1" Content="⏻" Height="60" FontSize="20" Margin="5,20,5,20" Background="#D32F2F" Foreground="White" FontWeight="Bold" BorderBrush="Transparent" Click="BtnExit_Click" Cursor="Hand"/>
                    </Grid>

                    <Button x:Name="BtnToggleMenu" Grid.Column="1" Content="▶" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnToggleMenu_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>