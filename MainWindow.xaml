<Window x:Class="NovaniX_EM2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:NovaniX_EM2.ViewModels"
        xmlns:views="clr-namespace:NovaniX_EM2.Views"
        Title="NovaniX EM2 - Multi Controller" 
        Height="700" Width="1100" 
        MinWidth="640" MinHeight="512"
        WindowStyle="None" ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <viewmodels:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="MenuListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="5,15"/>
            <Setter Property="Foreground" Value="#B0BEC5"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="5,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34495E"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1A252F"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#4CAF50"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
            <Grid>
                <Image Source="pack://application:,,,/Images/UnderLogo.png" 
                       Width="150" Height="35" Stretch="Uniform" HorizontalAlignment="Left"
                       VerticalAlignment="Center" Margin="10,0,0,0" 
                       RenderOptions.BitmapScalingMode="HighQuality" 
                       MouseLeftButtonDown="Logo_MouseLeftButtonDown" Cursor="Hand"/>
                
                <TextBlock Text="EM Second Concept System" 
                           Foreground="White" FontSize="20" FontWeight="Bold" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="{Binding CurrentDateTime}" 
               Foreground="White" FontSize="16" FontWeight="SemiBold" 
               Margin="0,0,15,0" VerticalAlignment="Center"/>

                    <Button x:Name="BtnToggleMenu" Content="◀" FontSize="20" Foreground="White" Background="Transparent" 
            BorderThickness="0" Cursor="Hand" VerticalAlignment="Center" Click="BtnToggleMenu_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="MenuColumn" Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Background="#2C3E50">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="MenuListBox" Grid.Row="0" Background="Transparent" BorderThickness="0" SelectedIndex="0" 
                             ItemContainerStyle="{StaticResource MenuListItemStyle}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🖥️" Margin="0,0,10,0" FontSize="16"/>
                                <TextBlock x:Name="TxtMenuMain" Text="Main Control" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>

                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🧬" Margin="0,0,10,0" FontSize="16"/>
                                <TextBlock x:Name="TxtMenuBio" Text="Environment Control" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>

                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙️" Margin="0,0,10,0" FontSize="16"/>
                                <TextBlock x:Name="TxtMenuMotion" Text="Motion Control" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>

                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🧩" Margin="0,0,10,0" FontSize="16"/>
                                <TextBlock x:Name="TxtMenuEtc" Text="Etc Control" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>

                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🛠️" Margin="0,0,10,0" FontSize="16"/>
                                <TextBlock x:Name="TxtMenuSys" Text="System Parameter" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>

                    </ListBox>

                    <Button x:Name="BtnExit" Grid.Row="1" Content="⏻ EXIT" Background="#E74C3C" Foreground="White" 
                            FontSize="16" FontWeight="Bold" Height="55" BorderThickness="0" Cursor="Hand" Click="BtnExit_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <TabControl Grid.Row="0" SelectedIndex="{Binding ElementName=MenuListBox, Path=SelectedIndex}" BorderThickness="0" Background="#F4F6F8">
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </Style>
                    </TabControl.ItemContainerStyle>

                    <TabItem>
                        <views:MainControlView />
                    </TabItem>

                    <TabItem>
                        <views:BioControlView />
                    </TabItem>

                    <TabItem>
                        <views:MotionControlView />
                    </TabItem>

                    <TabItem>
                        <Grid>
                            <TextBlock Text="Etc Machine Control 준비 중..." FontSize="24" FontWeight="SemiBold" Foreground="#999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </TabItem>

                    <TabItem>
                        <Grid>
                            <TextBlock Text="System Parameter 준비 중..." FontSize="24" FontWeight="SemiBold" Foreground="#999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </TabItem>
                </TabControl>

                <StatusBar Grid.Row="1" Background="#0D47A1" Foreground="White" HorizontalAlignment="Stretch">

                    <StatusBar.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                            </Grid>
                        </ItemsPanelTemplate>
                    </StatusBar.ItemsPanel>

                    <StatusBarItem Grid.Column="0" Margin="10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding StatusMessage, FallbackValue='Ready.'}"/>

                            <Separator Background="#3F51B5" Margin="10,0"/>

                            <TextBlock Text="COM Port: "/>
                            <TextBlock Text="{Binding SelectedPort, TargetNullValue='None'}" FontWeight="Bold"/>

                            <Separator Background="#3F51B5" Margin="10,0"/>

                            <TextBlock Text="⚠ 시스템 알람 발생" Foreground="#FF5252" FontWeight="Bold" 
                                       Visibility="{Binding IsAlarmed, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </StatusBarItem>

                    <StatusBarItem Grid.Column="2" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                            <TextBlock Text="PMS_P/C: " VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <Ellipse Width="12" Height="12" Margin="0,0,15,0" VerticalAlignment="Center" Stroke="#888" StrokeThickness="1" ToolTip="Particle Counter">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#F44336"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsParticleConnected}" Value="True">
                                                <Setter Property="Fill" Value="#4CAF50"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <TextBlock Text="PMS_A/S: " VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <Ellipse Width="12" Height="12" Margin="0,0,15,0" VerticalAlignment="Center" Stroke="#888" StrokeThickness="1" ToolTip="Air Sampler">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#F44336"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAirSamplerConnected}" Value="True">
                                                <Setter Property="Fill" Value="#4CAF50"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <TextBlock Text="Motion: " VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <Ellipse Width="12" Height="12" Margin="0,0,15,0" VerticalAlignment="Center" Stroke="#888" StrokeThickness="1">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#F44336"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMotionConnected}" Value="True">
                                                <Setter Property="Fill" Value="#4CAF50"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <TextBlock Text="I/O: " VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <Ellipse Width="12" Height="12" Margin="0,0,15,0" VerticalAlignment="Center" Stroke="#888" StrokeThickness="1">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#F44336"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsIoConnected}" Value="True">
                                                <Setter Property="Fill" Value="#4CAF50"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <TextBlock Text="Gripper: " VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <Ellipse Width="12" Height="12" Margin="0,0,15,0" VerticalAlignment="Center" Stroke="#888" StrokeThickness="1">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#F44336"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGripperConnected}" Value="True">
                                                <Setter Property="Fill" Value="#4CAF50"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <TextBlock Text="QR Reader: " VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <Ellipse Width="12" Height="12" VerticalAlignment="Center" Stroke="#888" StrokeThickness="1">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#F44336"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsQrConnected}" Value="True">
                                                <Setter Property="Fill" Value="#4CAF50"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                        </StackPanel>
                    </StatusBarItem>
                </StatusBar>
            </Grid>
        </Grid>
    </Grid>
</Window>